<aside class="main-sidebar sidebar-dark-primary elevation-4">
    <a href="/" class="brand-link">
        <img src="~/Themes/dist/img/AdminLTELogo.png" alt="AdminLTE Logo" class="brand-image img-circle elevation-3" style="opacity: .8">
        <span class="brand-text font-weight-light">School Manager</span>
    </a>

    <div class="sidebar">
        <div class="user-panel mt-3 pb-3 mb-3 d-flex">
            <div class="info">
                <a href="#" class="d-block">@User.Identity?.Name</a>
            </div>
        </div>

        <nav class="mt-2">
            <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu" data-accordion="false">

                @if (User.IsInRole("Admin"))
                {
                    <li class="nav-item">
                        <a href="/" class="nav-link">
                            <i class="nav-icon fas fa-tachometer-alt"></i>
                            <p>Dashboard</p>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a asp-controller="Students" asp-action="Index" class="nav-link">
                            <i class="nav-icon fas fa-user-graduate"></i>
                            <p>Quản lý Học sinh</p>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a asp-controller="Employees" asp-action="Index" class="nav-link">
                            <i class="nav-icon fas fa-chalkboard-teacher"></i>
                            <p>Quản lý Giáo viên</p>
                        </a>
                    </li>
                }

                @if (User.IsInRole("Employee"))
                {
                    <li class="nav-header">KHU VỰC NHÂN VIÊN</li>
                    <li class="nav-item">
                        <a asp-controller="EmployeePortal" asp-action="Index" class="nav-link">
                            <i class="nav-icon fas fa-chalkboard-teacher"></i>
                            <p>Trang cá nhân Giáo viên</p>
                        </a>
                    </li>
                }

                @if (User.IsInRole("Student"))
                {
                    <li class="nav-header">HỌC SINH</li>
                    <li class="nav-item">
                        <a asp-controller="StudentPortal" asp-action="Index" class="nav-link">
                            <i class="nav-icon fas fa-book-reader"></i>
                            <p>Góc học tập</p>
                        </a>
                    </li>
                }

                <li class="nav-item mt-3">
                    <a asp-controller="Account" asp-action="Logout" class="nav-link text-danger">
                        <i class="nav-icon fas fa-sign-out-alt"></i>
                        <p>Đăng xuất</p>
                    </a>
                </li>

            </ul>
        </nav>
    </div>
</aside>