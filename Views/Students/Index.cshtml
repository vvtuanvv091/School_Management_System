@model IEnumerable<School_Management_System.Models.Student>

@{
    ViewData["Title"] = "Danh sách Học sinh";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

@section Scripts {
    <script src="~/Themes/plugins/datatables/jquery.dataTables.min.js"></script>
    <script src="~/Themes/plugins/datatables-bs4/js/dataTables.bootstrap4.min.js"></script>
    <script src="~/Themes/plugins/datatables-responsive/js/dataTables.responsive.min.js"></script>
    <script src="~/Themes/plugins/datatables-buttons/js/dataTables.buttons.min.js"></script>

    <script>
        $(function () {
            $("#studentTable").DataTable({
                "responsive": true,
                "lengthChange": false,
                "autoWidth": false,
                "buttons": ["copy", "csv", "excel", "pdf", "print"],
                "language": {
                    "search": "Tìm kiếm:",
                    "paginate": { "next": "Sau", "previous": "Trước" },
                    "info": "Hiển thị _START_ đến _END_ của _TOTAL_ học sinh",
                    "emptyTable": "Không có dữ liệu",
                    "zeroRecords": "Không tìm thấy kết quả phù hợp"
                }
            }).buttons().container().appendTo('#studentTable_wrapper .col-md-6:eq(0)');
        });
    </script>
}

<link rel="stylesheet" href="~/Themes/plugins/datatables-bs4/css/dataTables.bootstrap4.min.css">
<link rel="stylesheet" href="~/Themes/plugins/datatables-responsive/css/responsive.bootstrap4.min.css">

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Dữ liệu học sinh toàn trường</h3>
        <div class="card-tools">
            <a asp-action="Create" class="btn btn-success btn-sm">
                <i class="fas fa-user-plus"></i> Thêm học sinh mới
            </a>
        </div>
    </div>

    <div class="card-body">
        <table id="studentTable" class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Mã HS</th>
                    <th>Họ và Tên</th>
                    <th>Giới tính</th>
                    <th>Ngày sinh</th>
                    <th>Lớp</th>
                    <th>Trạng thái</th>
                    <th style="width: 120px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.StdId</td>

                        <td>
                            <strong>@item.StdLname @item.StdFname</strong><br />
                            <small class="text-muted">@item.StdEmail</small>
                        </td>

                        <td>
                            @if (item.StdGender == "Nam")
                            {
                                <span class="badge badge-primary">Nam</span>
                            }
                            else
                            {
                                <span class="badge badge-pink" style="background-color:pink; color:white">Nữ</span>
                            }
                        </td>

                        <td>@item.StdDob.ToString("dd/MM/yyyy")</td>

                        <td>
                            @if (item.StdClass != null && item.StdSection != null)
                            {
                                <span class="badge badge-info">@item.StdClass.ClassDescription@item.StdSection.SectionName</span>
                            }
                            else
                            {
                                <span class="text-muted">Chưa xếp lớp</span>
                            }
                        </td>

                        <td>
                            @if (item.StdStatus == "Đang học")
                            {
                                <span class="badge badge-success">Đang học</span>
                            }
                            else
                            {
                                <span class="badge badge-danger">@item.StdStatus</span>
                            }
                        </td>

                        <td>
                            <div class="btn-group">
                                <a asp-action="Edit" asp-route-id="@item.StdId" class="btn btn-info btn-sm" title="Sửa">
                                    <i class="fas fa-pencil-alt"></i>
                                </a>
                                <a asp-action="Details" asp-route-id="@item.StdId" class="btn btn-warning btn-sm" title="Xem">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.StdId" class="btn btn-danger btn-sm" title="Xóa">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>